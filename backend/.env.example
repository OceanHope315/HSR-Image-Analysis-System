NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/railway_security
TEST_MONGO_URI=mongodb://127.0.0.1:27017/railway_security_test
JWT_SECRET=abcdefghijklmnopqrstuvwxyz1111111111111111111111111
JWT_EXPIRES_IN=8h
CLIENT_ORIGIN=http://localhost:5174
UPLOAD_DIR=uploads/xrays
MAX_UPLOAD_SIZE=5242880
LOG_LEVEL=info
SOCKET_CORS_ORIGIN=http://localhost:5174
TRANSACTION_MODE=auto
SIMULATION_ENABLED=true
DEVICE_OFFLINE_AFTER_SECONDS=90
YOLO_SERVICE_URL=http://127.0.0.1:8000
YOLO_REQUEST_TIMEOUT_MS=30000
YOLO_HEALTH_TIMEOUT_MS=2000
GAS_TCP_ENABLED=true
GAS_TCP_HOST=127.0.0.1
GAS_TCP_PORT=502
GAS_CONNECT_TIMEOUT_MS=3000
GAS_RECONNECT_DELAY_MS=5000
GAS_DATA_TIMEOUT_MS=10000
GAS_CHANNEL_COUNT=2
GAS_SENSOR_TYPE=combustible
GAS_MAX_CONCENTRATION=1000000
GAS_CLEAR_ALARM_HEX=FA 01 10 00 0E 00 01 02 00 01 39 AA
DETECTION_DUPLICATE_WINDOW_SECONDS=15
DATABASE_RETRY_DELAY_MS=5000
SEED_DEFAULT_PASSWORD=
SEED_ADMIN_EMAIL=admin@163.com
SEED_INSPECTOR_EMAIL=inspector@example.local
SEED_VIEWER_EMAIL=viewer@example.local
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=AdminPass123
ARCHIVE_BEFORE_DATE=
